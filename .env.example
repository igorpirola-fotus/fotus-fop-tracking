# .env.example — copiar para .env.local e preencher para desenvolvimento local
# NUNCA commitar o .env.local no Git
# Em produção, usar: supabase secrets set NOME=valor

# ── Supabase (gerados automaticamente pelo supabase start localmente)
SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Meta Ads
# Pixel ID: Gerenciador de Eventos → seu Pixel → Configurações
META_PIXEL_ID=123456789012345
# Token CAPI: Gerenciador de Eventos → seu Pixel → API de Conversões → Gerar token (usar token de sistema)
META_CAPI_TOKEN=EAAxxxxxxxxxxxxxx

# ── RD Station Marketing
# Conta → Minha Conta → API Token
RD_API_TOKEN=xxxxxxxxxxxxxx

# ── WhatsApp Business API
# Meta Business → WhatsApp → Configurações da API → Token de acesso de sistema
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxx
# Meta Business → WhatsApp → Números de telefone → ID do número
WHATSAPP_PHONE_ID=1234567890123
# Definido por você — qualquer string segura
WHATSAPP_VERIFY_TOKEN=fotus_wh_verify_2025

# ── Google Analytics 4
# GA4 → Admin → Fluxos de dados → seu site → Measurement Protocol API secrets
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=xxxxxxxxxxxx

# ── Google Ads (Enhanced Conversions for Leads)
# Google Ads → Metas → Conversões → selecionar conversão → Detalhes da tag
GADS_CONVERSION_ID=AW-XXXXXXXXX
GADS_CONVERSION_LABEL_LEAD=AbCdEfGhIjKlMn
GADS_CONVERSION_LABEL_SQL=OpQrStUvWxYzAb
GADS_CONVERSION_LABEL_PURCHASE=CdEfGhIjKlMnOp
# Google Cloud Console → APIs → Google Ads API → Credenciais → Token do desenvolvedor
GADS_DEVELOPER_TOKEN=xxxxxxxxxxxxxxxxxxxx
# Google Ads → ID do cliente (sem hífens, ex: 1234567890)
GADS_CUSTOMER_ID=1234567890

# ── Google Meu Negócio
# Google Cloud Console → IAM → Contas de serviço → fotus-gmb-sync → Chave JSON
# Colar o conteúdo JSON completo como string (entre aspas simples)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"fotus-tracking",...}'

# ── ERP
# Definido em conjunto com o time de TI
ERP_WEBHOOK_SECRET=fotus_erp_webhook_secret_2025
